# -----------------------------------------------------------------------------
# Next.js Application Configuration
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# NextAuth.js Configuration
# -----------------------------------------------------------------------------
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# -----------------------------------------------------------------------------
# Laravel Backend API Configuration
# -----------------------------------------------------------------------------
# Ajusta el puerto según tu backend Laravel (8081 por defecto aquí)
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_LARAVEL_APP_URL=
API_URL=
LARAVEL_APP_URL=

# -----------------------------------------------------------------------------
# Laravel Sanctum / Cookies
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=
SESSION_DOMAIN=

# -----------------------------------------------------------------------------
# Opcional: Subdirectorio (solo si se usa en producción)
# -----------------------------------------------------------------------------
# BASEPATH=
# NEXTAUTH_BASEPATH=
