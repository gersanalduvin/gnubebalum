# -----------------------------------------------------------------------------
# Next.js Application Configuration - PRODUCTION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# -----------------------------------------------------------------------------
# NextAuth.js Configuration - PRODUCTION
# -----------------------------------------------------------------------------
NEXTAUTH_URL=https://tu-dominio.com
NEXTAUTH_SECRET=tu-secreto-super-seguro-de-produccion

# -----------------------------------------------------------------------------
# Laravel Backend API Configuration - PRODUCTION
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.tu-dominio.com/api
NEXT_PUBLIC_LARAVEL_APP_URL=https://api.tu-dominio.com
API_URL=https://api.tu-dominio.com/api
LARAVEL_APP_URL=https://api.tu-dominio.com

# -----------------------------------------------------------------------------
# Laravel Sanctum / Cookies - PRODUCTION
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=tu-dominio.com
SESSION_DOMAIN=tu-dominio.com

# -----------------------------------------------------------------------------
# Optimizaciones de rendimiento
# -----------------------------------------------------------------------------
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1

# -----------------------------------------------------------------------------
# Configuración de cache y CDN (opcional)
# -----------------------------------------------------------------------------
# CDN_URL=https://cdn.tu-dominio.com
# STATIC_URL=https://static.tu-dominio.com